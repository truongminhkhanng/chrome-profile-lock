{
  "manifest_version": 3,
  "name": "Profile Lock Lite",
  "version": "2.2.0",
  "description": "Bảo vệ phiên Chrome bằng mã PIN 4/6 số, recovery code, khóa website và tự động khóa.",
  "icons": {
    "16": "src/assets/icon16.png",
    "32": "src/assets/icon32.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "windows",
    "idle",
    "alarms",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Profile Lock Lite",
    "default_icon": {
      "16": "src/assets/icon16.png",
      "32": "src/assets/icon32.png",
      "48": "src/assets/icon48.png",
      "128": "src/assets/icon128.png"
    },
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "commands": {
    "lock-now": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Khóa Profile Lock Lite ngay"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/lock.css", "src/lock.html", "src/pin-input.js", "src/pin-input.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
